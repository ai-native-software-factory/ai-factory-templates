  },
  "keywords": ["iplayabc", "nestjs", "common", "database", "cache", "auth"],
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
